# ==============================================================================
# KUNAI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# DO NOT commit real API keys to version control.
# Copy this file to `.env` or `.env.local` for development.
# ==============================================================================

# ── Cloudflare CORS Proxy (For Web App & Free Tier) ──────────────────────────
# URL of your deployed Cloudflare Worker acting as the CORS proxy.
NEXT_PUBLIC_KUNAI_PROXY_URL="https://proxy.kunai.app"

# ── Cryptographic Security (WASM Signature Verification) ─────────────────────
# A secure, rotating secret string used to salt the HMAC-SHA256 hashes generated
# by the open-source CLI client. The backend requires this to prevent leeching.
# E.g., generate via `openssl rand -hex 32`
KUNAI_WASM_SALT="change_me_to_a_secure_random_string_in_production"

# ── Premium Cloud Services (Supabase / Database) ─────────────────────────────
# Used for the $3/mo Premium Tier "Kunai Sync" (Cross-device history).
NEXT_PUBLIC_SUPABASE_URL="your_supabase_project_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# ── User Preferences (Client-Side Storage) ───────────────────────────────────
# If the user is running the Desktop/CLI app, they can provide a Real-Debrid 
# API key locally to unlock premium torrent caching. 
# THIS MUST NEVER BE SENT TO OUR SERVERS. It stays in their local SQLite/LocalStorage.
# REAL_DEBRID_API_KEY="user_provided_key_only"
